      "signedByRoot": true
    },
    "code": {
      "keyId": "code-2026",
      "algo": "ed25519",
      "publicKeyHex": "REPLACE_WITH_CODE_SIGNING_PUBLIC_KEY_HEX",
      "threshold": 2,
      "signedByRoot": true
    },
    "snapshot": {
      "keyId": "snapshot-2026",
      "algo": "ed25519",
      "publicKeyHex": "REPLACE_WITH_SNAPSHOT_PUBLIC_KEY_HEX",
      "signedByRoot": true
    },
    "timestamp": {
      "keyId": "timestamp-2026",
      "algo": "ed25519",
      "publicKeyHex": "REPLACE_WITH_TIMESTAMP_PUBLIC_KEY_HEX",
