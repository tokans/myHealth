{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability grants for the desktop and mobile builds.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "os:default",
    "dialog:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$APPDATA/**" }, { "path": "$LOCALDATA/**" }]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [{ "path": "$HOME/**" }, { "path": "$DOCUMENT/**" }, { "path": "$DOWNLOAD/**" }, { "path": "$APPDATA/**" }, { "path": "$LOCALDATA/**" }]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$LOCALDATA/**" }]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$LOCALDATA/**" }]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [{ "path": "$APPDATA/**" }, { "path": "$LOCALDATA/**" }]
    },
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/*" },
        { "url": "https://www.tokans.org" },
        { "url": "https://www.tokans.org/*" },
        { "url": "https://tokans.org" },
        { "url": "https://tokans.org/*" },
        { "url": "tel:*" },
        { "url": "mailto:*" }
      ]
    },
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "stronghold:default",
    "notification:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://github.com/*" },
        { "url": "https://objects.githubusercontent.com/*" },
        { "url": "https://release-assets.githubusercontent.com/*" },
        { "url": "http://localhost:4321/*" }
      ]
    }
  ]
}
